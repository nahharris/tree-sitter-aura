{
  "name": "tree-sitter-aura",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Aura",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "parser",
    "tree-sitter",
    "aura"
  ],
  "author": "Hannah Harrisonn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nahharris/tree-sitter-aura"
  },
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.20.8"
  },
  "tree-sitter": [
    {
      "scope": "source.aura",
      "file-types": [
        "aura"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": "queries/injections.scm"
    }
  ]
}
